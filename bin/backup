#!/bin/bash
set -e

DB_PATH="${1:-/rails/storage/production.sqlite3}"
BACKUP_DIR="${2:-/rails/storage/backups}"
KEEP_DAYS="${3:-7}"

mkdir -p "$BACKUP_DIR"

TIMESTAMP=$(date +"%Y%m%d_%H%M%S")
BACKUP_FILE="$BACKUP_DIR/production_${TIMESTAMP}.sqlite3"

echo "[backup] Iniciando backup de $DB_PATH para $BACKUP_FILE"

sqlite3 "$DB_PATH" ".backup '$BACKUP_FILE'"

if [ -f "$BACKUP_FILE" ]; then
  echo "[backup] Backup concluído: $BACKUP_FILE"
else
  echo "[backup] ERRO: Backup falhou"
  exit 1
fi

find "$BACKUP_DIR" -name "production_*.sqlite3" -mtime +$KEEP_DAYS -delete
echo "[backup] Backups anteriores a $KEEP_DAYS dias removidos"

exit 0
